properties([
    parameters([

        [
            $class: 'ChoiceParameter',
            choiceType: 'PT_SINGLE_SELECT',
            name: 'SERVER',
            description: 'Select the target server',
            filterable: false,
            script: [
                $class: 'GroovyScript',
                script: [
                    sandbox: false,
                    script: '''
                        def root = new File("/opt/jenkins/config-cache/servers")

                        if (!root.exists()) {
                            return ["Run Config Sync Job"]
                        }

                        return root.listFiles()
                                   .findAll { it.isDirectory() }
                                   .collect { it.name }
                                   .sort()
                    '''
                ]
            ]
        ],

        [
            $class: 'CascadeChoiceParameter',
            choiceType: 'PT_SINGLE_SELECT',
            name: 'SERVICE',
            description: 'Select the target service',
            referencedParameters: 'SERVER',
            filterable: false,
            script: [
                $class: 'GroovyScript',
                script: [
                    sandbox: false,
                    script: '''
                        if (!SERVER) {
                            return []
                        }

                        def root = new File("/opt/jenkins/config-cache/servers/${SERVER}")

                        if (!root.exists()) {
                            return ["No Services Found"]
                        }

                        return root.listFiles()
                                   .findAll { it.isDirectory() }
                                   .collect { it.name }
                                   .sort()
                    '''
                ]
            ]
        ],

        [
            $class: 'CascadeChoiceParameter',
            choiceType: 'PT_SINGLE_SELECT',
            name: 'ENVIRONMENT',
            description: 'Select the deployment environment',
            referencedParameters: 'SERVER,SERVICE',
            filterable: false,
            script: [
                $class: 'GroovyScript',
                script: [
                    sandbox: false,
                    script: '''
                        if (!SERVER || !SERVICE) {
                            return []
                        }

                        def serviceDir = new File("/opt/jenkins/config-cache/servers/${SERVER}/${SERVICE}")

                        if (!serviceDir.exists()) {
                            return ["No Environment Found"]
                        }

                        return serviceDir.listFiles()
                                         .findAll {
                                             it.isFile() &&
                                             (it.name.endsWith(".yaml") || it.name.endsWith(".yml"))
                                         }
                                         .collect {
                                             it.name.replaceAll(/\\.ya?ml$/, "")
                                         }
                                         .sort()
                    '''
                ]
            ]
        ],

        booleanParam(
            name: 'DRY_RUN',
            defaultValue: false,
            description: 'Skip deployment'
        )

    ])
])

pipeline {

    agent any

    stages {

        stage('Validate') {
            steps {
                script {
                    echo """
                    ============================
                    Deployment Configuration
                    ============================
                    Server      : ${params.SERVER}
                    Service     : ${params.SERVICE}
                    Environment : ${params.ENVIRONMENT}
                    Dry Run     : ${params.DRY_RUN}
                    ============================
                    """
                }
            }
        }

        stage('Deploy') {
            when {
                expression { !params.DRY_RUN }
            }

            steps {
                script {

                    def configFile = "/opt/jenkins/config-cache/servers/${params.SERVER}/${params.SERVICE}/${params.ENVIRONMENT}.yaml"

                    echo "Using configuration:"
                    echo configFile

                    // Example:
                    // def cfg = readYaml file: configFile
                    // sh "helm upgrade ..."
                    // sh "kubectl apply -f ${configFile}"

                }
            }
        }

    }

}