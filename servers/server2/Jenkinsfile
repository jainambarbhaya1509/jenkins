// ============================================================
// This Jenkinsfile is scoped to a single server. Change
// SERVER_NAME below if you copy this for another server.
// It must match the literal string inside the Groovy scripts
// too, since Active Choice scripts run standalone and can't
// read Jenkinsfile-level variables.
//
// This version reads directly from GitHub via the REST API
// instead of any local filesystem path or cache. No sync job,
// no volume mount, no workspace dependency required.
// ============================================================
def SERVER_NAME  = "server2"
def GITHUB_REPO  = "jainambarbhaya1509/jenkins"
def GITHUB_BRANCH = "main"

properties([
    parameters([

        [
            $class: 'ChoiceParameter',
            choiceType: 'PT_SINGLE_SELECT',
            name: 'SERVICE',
            description: 'Select the target service',
            filterable: false,
            script: [
                $class: 'GroovyScript',
                script: [
                    sandbox: true,
                    script: '''import groovy.json.JsonSlurper

                        def serverName = "server2" // must match SERVER_NAME above
                        def repo = "jainambarbhaya1509/jenkins"
                        def branch = "main"

                        try {
                            def url = "https://api.github.com/repos/${repo}/contents/servers/${serverName}?ref=${branch}"
                            def response = url.toURL().text
                            def items = new JsonSlurper().parseText(response)

                            def services = items.findAll { it.type == "dir" }
                                                 .collect { it.name }
                                                 .sort()

                            return services.isEmpty() ? ["No Services Found"] : services
                        } catch (e) {
                            return [e.toString()]
                        }
                    ''',
                ],
                fallbackScript: [
                    sandbox: true,
                    script: 'return ["No Services Found"]'
                ]
            ]
        ],

        [
            $class: 'CascadeChoiceParameter',
            choiceType: 'PT_SINGLE_SELECT',
            name: 'ENVIRONMENT',
            description: 'Select the deployment environment',
            referencedParameters: 'SERVICE',
            filterable: false,
            script: [
                $class: 'GroovyScript',
                script: [
                    sandbox: true,
                    script: '''import groovy.json.JsonSlurper

                        def serverName = "server2" // must match SERVER_NAME above
                        def repo = "jainambarbhaya1509/jenkins"
                        def branch = "main"

                        if (!SERVICE) {
                            return []
                        }

                        try {
                            def url = "https://api.github.com/repos/${repo}/contents/servers/${serverName}/${SERVICE}?ref=${branch}"
                            def response = url.toURL().text
                            def items = new JsonSlurper().parseText(response)

                            def envs = items.findAll {
                                                 it.type == "file" &&
                                                 (it.name.endsWith(".yaml") || it.name.endsWith(".yml"))
                                             }
                                             .collect { it.name.replaceAll(/\\.ya?ml$/, "") }
                                             .sort()

                            return envs.isEmpty() ? ["No Environment Found"] : envs
                        } catch (e) {
                            return [e.toString()]
                        }
                    ''',
                ],
                fallbackScript: [
                    sandbox: true,
                    script: 'return ["No Environment Found"]'
                ]
            ]
        ],

        booleanParam(
            name: 'DRY_RUN',
            defaultValue: false,
            description: 'Skip deployment'
        )

    ])
])

pipeline {

    agent any

    stages {

        stage('Validate') {
            steps {
                script {
                    if (params.SERVICE in ["No Services Found"] ||
                        params.ENVIRONMENT in ["No Environment Found"]) {
                        error("Invalid selection. SERVER=${SERVER_NAME}, SERVICE=${params.SERVICE}, ENVIRONMENT=${params.ENVIRONMENT}")
                    }

                    echo """
                    ============================
                    Deployment Configuration
                    ============================
                    Server      : ${SERVER_NAME}
                    Service     : ${params.SERVICE}
                    Environment : ${params.ENVIRONMENT}
                    Dry Run     : ${params.DRY_RUN}
                    ============================
                    """
                }
            }
        }

        stage('Deploy') {
            when {
                expression { !params.DRY_RUN }
            }

            steps {
                script {
                    def rawUrl = "https://raw.githubusercontent.com/${GITHUB_REPO}/${GITHUB_BRANCH}/servers/${SERVER_NAME}/${params.SERVICE}/${params.ENVIRONMENT}.yaml"

                    echo "Fetching configuration from:"
                    echo rawUrl

                    def configContent = sh(script: "curl -fsSL '${rawUrl}'", returnStdout: true).trim()

                    writeFile file: 'deploy-config.yaml', text: configContent

                    echo "Using configuration:"
                    echo configContent

                    // Example:
                    // def cfg = readYaml file: 'deploy-config.yaml'
                    // sh "helm upgrade ..."
                    // sh "kubectl apply -f deploy-config.yaml"
                }
            }
        }

    }

}