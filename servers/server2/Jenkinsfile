// ============================================================
// This Jenkinsfile is scoped to a single server. Change this
// value if you copy this file for another server, or better,
// template it out per-server via your job-DSL / seed job.
// It must match the literal string inside the Groovy scripts
// below too, since Active Choice scripts run standalone and
// can't read Jenkinsfile-level variables.
// ============================================================
def SERVER_NAME = "server2"

properties([
    parameters([

        [
            $class: 'ChoiceParameter',
            choiceType: 'PT_SINGLE_SELECT',
            name: 'SERVICE',
            description: 'Select the target service',
            filterable: false,
            script: [
                $class: 'GroovyScript',
                script: [
                    sandbox: false,
                    script: '''
                        def serverName = "server2" // must match SERVER_NAME above

                        def root = new File("/opt/jenkins/config-cache/servers/${serverName}")

                        if (!root.exists()) {
                            return ["Run Config Sync Job"]
                        }

                        def dirs = root.listFiles()
                        if (dirs == null) {
                            return ["No Services Found"]
                        }

                        return dirs.findAll { it.isDirectory() }
                                   .collect { it.name }
                                   .sort()
                    '''
                ]
            ]
        ],

        [
            $class: 'CascadeChoiceParameter',
            choiceType: 'PT_SINGLE_SELECT',
            name: 'ENVIRONMENT',
            description: 'Select the deployment environment',
            referencedParameters: 'SERVICE',
            filterable: false,
            script: [
                $class: 'GroovyScript',
                script: [
                    sandbox: false,
                    script: '''
                        def serverName = "server1" // must match SERVER_NAME above

                        if (!SERVICE) {
                            return []
                        }

                        def serviceDir = new File("/opt/jenkins/config-cache/servers/${serverName}/${SERVICE}")

                        if (!serviceDir.exists()) {
                            return ["No Environment Found"]
                        }

                        def files = serviceDir.listFiles()
                        if (files == null) {
                            return ["No Environment Found"]
                        }

                        def envs = files.findAll {
                                            it.isFile() &&
                                            (it.name.endsWith(".yaml") || it.name.endsWith(".yml"))
                                        }
                                        .collect {
                                            it.name.replaceAll(/\\.ya?ml$/, "")
                                        }
                                        .sort()

                        return envs.isEmpty() ? ["No Environment Found"] : envs
                    ''',
                ],
                fallbackScript: [
                    sandbox: false,
                    script: 'return ["No Environment Found"]'
                ]
            ]
        ],

        booleanParam(
            name: 'DRY_RUN',
            defaultValue: false,
            description: 'Skip deployment'
        )

    ])
])

pipeline {

    agent any

    stages {

        stage('Validate') {
            steps {
                script {
                    if (params.SERVICE in ["No Services Found"] ||
                        params.ENVIRONMENT in ["No Environment Found"] ||
                        params.SERVER in ["Run Config Sync Job", "No Servers Found"]) {
                        error("Invalid selection. SERVER=${params.SERVER}, SERVICE=${params.SERVICE}, ENVIRONMENT=${params.ENVIRONMENT}")
                    }

                    echo """
                    ============================
                    Deployment Configuration
                    ============================
                    Server      : ${params.SERVER}
                    Service     : ${params.SERVICE}
                    Environment : ${params.ENVIRONMENT}
                    Dry Run     : ${params.DRY_RUN}
                    ============================
                    """
                }
            }
        }

        stage('Deploy') {
            when {
                expression { !params.DRY_RUN }
            }

            steps {
                script {

                    def configFile = "/opt/jenkins/config-cache/servers/${params.SERVER}/${params.SERVICE}/${params.ENVIRONMENT}.yaml"

                    if (!fileExists(configFile)) {
                        error("Config file not found: ${configFile}")
                    }

                    echo "Using configuration:"
                    echo configFile

                    // Example:
                    // def cfg = readYaml file: configFile
                    // sh "helm upgrade ..."
                    // sh "kubectl apply -f ${configFile}"

                }
            }
        }

    }

}