properties([
    parameters([
        [
            $class: 'ChoiceParameter',
            choiceType: 'PT_SINGLE_SELECT',
            description: 'Select the target environment',
            filterLength: 1,
            filterable: false,
            name: 'ENVIRONMENT',
            script: [
                $class: 'GroovyScript',
                script: [
                    classpath: [],
                    sandbox: true,
                    script: '''
                        return [
                            'dev',
                            'qa'
                        ]
                    '''
                ]
            ]
        ],
        [
            $class: 'ChoiceParameter',
            choiceType: 'PT_SINGLE_SELECT',
            description: 'Select the target service',
            filterLength: 1,
            filterable: false,
            name: 'SERVICE',
            script: [
                $class: 'GroovyScript',
                script: [
                    classpath: [],
                    sandbox: true,
                    script: '''
                        return [
                            'service1',
                            'service2'
                        ]
                    '''
                ]
            ]
        ],
        [
            $class: 'BooleanParameterDefinition',
            name: 'DRY_RUN',
            defaultValue: false,
            description: 'Refresh configuration cache only'
        ]
    ])
])

def configDir = '/opt/jenkins/config-cache'
def configRepo = 'https://github.com/jainambarbhaya1509/jenkins.git'

node {

    stage('Clone Config Repo') {

        if (params.DRY_RUN) {

            if (!fileExists("${configDir}/.git")) {
                echo 'Cloning config repo...'
                sh "git clone '${configRepo}' '${configDir}'"
            } else {
                echo 'Updating config repo...'
                dir(configDir) {
                    sh '''
                        git fetch origin
                        git reset --hard origin/main
                    '''
                }
            }

        }

    }

    stage('Exit') {

        if (params.DRY_RUN) {
            echo 'Configuration cache refreshed.'
            echo 'Open Build With Parameters again.'
        }

    }

}